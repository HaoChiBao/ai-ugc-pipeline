# Required: same key as the Next.js app (see client/.env.example)
GEMINI_API_KEY=

# Optional — defaults match client/.env.example
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Optional image generation tuning (see Google Gen AI ImageConfig)
GEMINI_ASPECT_RATIO=9:16
GEMINI_IMAGE_SIZE=2K

# Caption slideshow (`run_captioned_slideshow.py`) — OpenAI JSON plan
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Vision model for analyze_tiktok_slideshow.py (must support image inputs)
# OPENAI_VISION_MODEL=gpt-4o

# Or use Gemini for captions: `run_captioned_slideshow.py --provider gemini`
GEMINI_TEXT_MODEL=gemini-2.0-flash

# Optional: bold sans for TikTok text (Windows often finds Arial Bold automatically)
# TIKTOK_FONT_PATH=C:\Windows\Fonts\arialbd.ttf
