# Google AI Studio / Gemini API (same key as other Gemini tools)
GEMINI_API_KEY=
# Optional overrides
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_ASPECT_RATIO=9:16
GEMINI_IMAGE_SIZE=2K

# Where uploads + generated PNGs are stored (created automatically)
DATA_DIR=./data

# Public URL prefix for /static (used in JSON responses; default 127.0.0.1:8000)
PUBLIC_BASE_URL=http://127.0.0.1:8000
